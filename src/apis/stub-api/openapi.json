{
  "openapi": "3.0.3",
  "info": {
    "title": "Stub API",
    "description": "A demo stub API to demonstrate the extensibility of the Developer Portal. Adding this API required zero component changes.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "https://jsonplaceholder.typicode.com", "description": "JSONPlaceholder (Free fake REST API)" }
  ],
  "tags": [
